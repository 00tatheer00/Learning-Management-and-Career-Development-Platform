# Database (MongoDB)
DATABASE_URL="mongodb+srv://user:pass@cluster.mongodb.net/eest?retryWrites=true&w=majority"
# Optional: direct connection for migrations in dev
# DATABASE_URL_DIRECT=

# Auth (required in production)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-string"
# Separate secret for encrypting stored portal passwords (recommended in production)
PORTAL_PASSWORD_SECRET="generate-another-long-random-string"

# Seed passwords (required when running db:seed in production)
SEED_ADMIN_PASSWORD=
SEED_KOMAL_PASSWORD=
SEED_TRAINER_TATHEER_PASSWORD=
SEED_TRAINER_ZUNIRA_PASSWORD=

# Cloudinary (payment screenshots)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend) — optional
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
CONTACT_INBOX_EMAIL=
# Route student class/assignment emails to demo inbox only (set false for all students)
STUDENT_EMAIL_DEMO_ONLY=true

# WhatsApp (UltraMsg) — optional; only safe transactional messages are sent
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
ADMIN_ALERT_WHATSAPP=

# Rate limiting (Upstash Redis) — optional; in-memory fallback used if unset
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron automation endpoint
CRON_SECRET=

# Public
NEXT_PUBLIC_STUDENT_WHATSAPP_GROUP_URL=

# Video (Jitsi fallback domain)
JITSI_DOMAIN=meet.jit.si
