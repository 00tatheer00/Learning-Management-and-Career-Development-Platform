generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  trainer
  admin
  admin_readonly
}

enum EnrollmentStatus {
  pending
  approved
  rejected
}

enum MaterialType {
  video
  link
  document
}

enum SubmissionStatus {
  submitted
  approved
  needs_revision
}

model PasswordResetToken {
  id        String   @id @map("_id")
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id              String   @id @map("_id")
  email           String   @unique
  passwordHash    String
  role            UserRole
  name            String
  phone           String?
  programSlug     String?
  level           String?
  batch           String?  @default("Batch 1")
  trainerId       String?
  avatarInitials  String?
  avatarUrl       String?
  designation     String?
  bio             String?
  experience      String?
  expertise       String[] @default([])
  imagePosition   String?
  isActive        Boolean  @default(true)
  activeSessionId String?
  firstLoginAt    DateTime?
  lastLoginAt     DateTime?
  lastActiveAt    DateTime?
  createdAt       DateTime @default(now())

  submissions AssignmentSubmission[] @relation("StudentSubmissions")
  attendance  ClassAttendance[]        @relation("StudentAttendance")
}

model Enrollment {
  id                        String           @id @map("_id")
  fullName                  String
  fatherName                String
  institution               String
  classSemester             String
  cnic                      String
  email                     String
  whatsapp                  String
  fieldOfStudy              String
  program                   String
  level                     String
  batch                     String           @default("Batch 1")
  learningMode              String
  hasLaptop                 String
  internetAvailable         String
  confirmInfoCorrect        Boolean
  agreeToPolicies           Boolean
  paymentScreenshot         String?
  paymentScreenshotPublicId String?
  profilePhotoUrl           String?
  profilePhotoPublicId      String?
  /// Encrypted portal password for admin reveal / WhatsApp — login uses User.passwordHash
  portalPasswordEnc         String?
  status                    EnrollmentStatus @default(pending)
  reviewedAt                DateTime?
  reviewedBy                String?
  adminNotes                String?
  approvalWhatsAppSent      Boolean?
  approvalWhatsAppError     String?
  createdAt                 DateTime         @default(now())
}

model CourseMaterial {
  id          String       @id @map("_id")
  programSlug String
  title       String
  description String
  type        MaterialType
  url         String
  order       Int
}

model Assignment {
  id          String   @id @map("_id")
  programSlug String
  title       String
  description String
  dueDate     String
  trainerId   String
  createdAt   DateTime @default(now())

  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String           @id @map("_id")
  assignmentId String
  studentId    String
  studentName  String
  content      String
  status       SubmissionStatus @default(submitted)
  submittedAt  DateTime         @default(now())
  feedback     String?
  reviewedAt   DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id           String    @id @map("_id")
  programSlug  String
  title        String
  startsAt     DateTime?
  timezone     String    @default("Asia/Karachi")
  date         String
  time         String
  meetLink     String    @default("")
  roomType     String    @default("meet")
  roomName     String?
  roomPassword String?
  trainerId    String
  trainerName  String
  notes        String?

  attendances ClassAttendance[]
}

model AutomationSendLog {
  id     String   @id @map("_id")
  key    String   @unique
  type   String
  sentAt DateTime @default(now())
}

model ClassAttendance {
  id          String   @id @map("_id")
  sessionId   String
  studentId   String
  studentName String
  programSlug String
  sessionDate String
  sessionTime String
  joinedAt    DateTime @default(now())
  status      String

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User        @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}

model ClassRecording {
  id          String   @id @map("_id")
  programSlug String
  classNumber Int
  title       String
  driveUrl    String
  trainerId   String
  trainerName String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([programSlug, classNumber])
}
