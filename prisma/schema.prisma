generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  trainer
  admin
  admin_readonly
}

enum EnrollmentStatus {
  pending
  approved
  rejected
}

enum MaterialType {
  video
  link
  document
}

enum SubmissionStatus {
  submitted
  approved
  needs_revision
}

model PasswordResetToken {
  id        String   @id @map("_id")
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id              String   @id @map("_id")
  email           String   @unique
  passwordHash    String
  role            UserRole
  name            String
  phone           String?
  programSlug     String?
  level           String?
  batch           String?  @default("Batch 1")
  trainerId       String?
  avatarInitials  String?
  avatarUrl       String?
  designation     String?
  bio             String?
  experience      String?
  expertise       String[] @default([])
  imagePosition   String?
  isActive        Boolean  @default(true)
  activeSessionId String?
  firstLoginAt        DateTime?
  lastLoginAt         DateTime?
  lastActiveAt        DateTime?
  assignmentsSeenAt   DateTime?
  classesSeenAt       DateTime?
  createdAt           DateTime @default(now())

  submissions AssignmentSubmission[] @relation("StudentSubmissions")
  attendance  ClassAttendance[]        @relation("StudentAttendance")
}

model Enrollment {
  id                        String           @id @map("_id")
  fullName                  String
  fatherName                String
  institution               String
  classSemester             String
  cnic                      String
  email                     String
  whatsapp                  String
  fieldOfStudy              String
  program                   String
  level                     String
  batch                     String           @default("Batch 1")
  learningMode              String
  hasLaptop                 String
  internetAvailable         String
  confirmInfoCorrect        Boolean
  agreeToPolicies           Boolean
  paymentScreenshot         String?
  paymentScreenshotPublicId String?
  profilePhotoUrl           String?
  profilePhotoPublicId      String?
  /// Encrypted portal password for admin reveal / WhatsApp — login uses User.passwordHash
  portalPasswordEnc         String?
  status                    EnrollmentStatus @default(pending)
  reviewedAt                DateTime?
  reviewedBy                String?
  adminNotes                String?
  approvalEmailSent         Boolean?
  approvalEmailError        String?
  approvalWhatsAppSent      Boolean?
  approvalWhatsAppError     String?
  portalWelcomeShownAt      DateTime?
  createdAt                 DateTime         @default(now())
}

model CourseMaterial {
  id          String       @id @map("_id")
  programSlug String
  level       String?
  title       String
  description String
  type        MaterialType
  url         String
  order       Int
}

model Assignment {
  id          String   @id @map("_id")
  programSlug String
  level       String?
  title       String
  description String
  dueDate     String
  trainerId   String
  createdAt   DateTime @default(now())

  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String           @id @map("_id")
  assignmentId String
  studentId    String
  studentName  String
  content      String
  status       SubmissionStatus @default(submitted)
  submittedAt  DateTime         @default(now())
  feedback     String?
  reviewedAt   DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
}

model LiveSession {
  id           String    @id @map("_id")
  programSlug  String
  level        String?
  title        String
  startsAt     DateTime?
  timezone     String    @default("Asia/Karachi")
  date         String
  time         String
  meetLink     String    @default("")
  roomType     String    @default("meet")
  roomName     String?
  roomPassword String?
  trainerId    String
  trainerName  String
  notes        String?
  createdAt    DateTime  @default(now())

  attendances ClassAttendance[]
}

model AutomationSendLog {
  id     String   @id @map("_id")
  key    String   @unique
  type   String
  sentAt DateTime @default(now())
}

model ClassAttendance {
  id          String   @id @map("_id")
  sessionId   String
  studentId   String
  studentName String
  programSlug String
  sessionDate String
  sessionTime String
  joinedAt    DateTime @default(now())
  status      String
  /// portal_join | manual
  markSource  String?
  markedBy    String?
  adminNote   String?

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User        @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}

model ClassRecording {
  id          String   @id @map("_id")
  programSlug String
  level       String?
  classNumber Int
  title       String
  driveUrl    String
  trainerId   String
  trainerName String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([programSlug, classNumber])
}

// ─── WhatsApp Cloud API CRM ───────────────────────────────────────────────────

enum WhatsAppMessageDirection {
  inbound
  outbound
}

enum WhatsAppMessageType {
  text
  image
  document
  audio
  video
  sticker
  location
  contacts
  template
  interactive
  reaction
  unknown
}

enum WhatsAppDeliveryStatus {
  pending
  sent
  delivered
  read
  failed
}

enum WhatsAppConversationStatus {
  open
  archived
  blocked
}

model WhatsAppContact {
  id           String   @id @map("_id")
  waId         String   @unique
  phoneE164    String
  displayName  String?
  profileName  String?
  userId       String?
  enrollmentId String?
  isBlocked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations WhatsAppConversation[]
  messages      WhatsAppMessage[]

  @@index([userId])
  @@index([enrollmentId])
  @@index([phoneE164])
}

model WhatsAppConversation {
  id                 String                     @id @map("_id")
  contactId          String                     @unique
  status             WhatsAppConversationStatus @default(open)
  assignedAgentId    String?
  assignedAgentName  String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  unreadCount        Int                        @default(0)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  contact  WhatsAppContact                @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages WhatsAppMessage[]
  notes    WhatsAppConversationNote[]
  labels   WhatsAppConversationLabelMap[]

  @@index([lastMessageAt])
  @@index([assignedAgentId])
  @@index([status])
  @@index([unreadCount])
}

model WhatsAppMessage {
  id                     String                   @id @map("_id")
  conversationId         String
  contactId              String
  wamid                  String?                  @unique
  clientMessageId        String?                  @unique
  direction              WhatsAppMessageDirection
  type                   WhatsAppMessageType      @default(text)
  body                   String?
  mediaId                String?
  mediaUrl               String?
  mediaMimeType          String?
  mediaFilename          String?
  mediaSha256            String?
  locationLat            Float?
  locationLng            Float?
  locationName           String?
  locationAddress        String?
  contactsJson           String?
  templateName           String?
  templateLanguage       String?
  templateComponentsJson String?
  reactionEmoji          String?
  reactionTargetWamid    String?
  status                 WhatsAppDeliveryStatus   @default(pending)
  statusError            String?
  purpose                String?
  sentByAgentId          String?
  sentByAgentName        String?
  isInternalNote         Boolean                  @default(false)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  sentAt                 DateTime?
  deliveredAt            DateTime?
  readAt                 DateTime?
  failedAt               DateTime?

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      WhatsAppContact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([contactId, createdAt])
  @@index([status])
  @@index([direction])
}

model WhatsAppConversationNote {
  id             String   @id @map("_id")
  conversationId String
  authorId       String
  authorName     String
  body           String
  createdAt      DateTime @default(now())

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model WhatsAppLabel {
  id        String   @id @map("_id")
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  conversations WhatsAppConversationLabelMap[]
}

model WhatsAppConversationLabelMap {
  id             String @id @map("_id")
  conversationId String
  labelId        String

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  label        WhatsAppLabel        @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([conversationId, labelId])
  @@index([labelId])
}

model WhatsAppTemplate {
  id             String   @id @map("_id")
  metaTemplateId String?
  name           String
  language       String   @default("en")
  category       String?
  status         String   @default("PENDING")
  bodyPreview    String?
  componentsJson String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([name, language])
  @@index([status])
}

model WhatsAppWebhookEvent {
  id          String   @id @map("_id")
  eventKey    String   @unique
  eventType   String
  processedAt DateTime @default(now())

  @@index([processedAt])
}
